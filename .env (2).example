# --- Server-side only (Netlify Functions). JANGAN pakai prefix VITE_ untuk
# variabel di bawah ini, supaya tidak ter-bundle ke frontend / kelihatan
# oleh browser. Ini dipakai oleh netlify/functions/sync-scores.js. ---

# Sama seperti VITE_SUPABASE_URL di atas, tapi tanpa prefix VITE_
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Project Settings > API > service_role key (RAHASIA, jangan pernah expose ke frontend)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SUPABASE-SERVICE-ROLE-KEY

# API-Football (api-sports.io) - daftar gratis di https://dashboard.api-football.com/register
